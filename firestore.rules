rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Signed-in users can read their own document.
      allow read: if request.auth != null && request.auth.uid == userId;

      // A user can create their own profile document, but only if it
      // starts at balance 0 — they can't create themselves a starting
      // balance out of thin air.
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.balance == 0;

      // A user can update their OWN document (e.g. change a display
      // name), but the incoming "balance" must be identical to what's
      // already stored. No client write, no matter how it's triggered
      // (normal app code, or someone calling updateDoc() straight from
      // dev tools), can ever change balance.
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.balance == resource.data.balance;

      // Admin account keeps full access. Real balance changes happen
      // through the backend's Admin SDK (which bypasses these rules
      // entirely), not by signing into the app as this account.
      allow read, write: if request.auth != null
                         && request.auth.uid == "GZOWtlF8OFSeM0E08epGicNHvAh2";
    }
  }
}
